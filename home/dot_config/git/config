[init]
	defaultBranch = main

[core]
  useConfigDir = true
  editor = nvim
  pager = delta

[user]
  name = yoxi
  email = yongxingzhao@foxmail.com
	signingkey = ~/.ssh/id_ed25519.pub

[interactive]
  diffFilter = delta --color-only

[delta]
  navigate = true
  dark = true
  line-numbers = true
  side-by-side = true

[merge]
  conflictStyle = zdiff3

[gpg]
	format = ssh

[commit]
	gpgsign = true

[color]
  ui = true
